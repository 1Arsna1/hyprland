{
	"user": {
		"format": "{user}",
		"interval": 60,
		"height": 30,
		"width": 30,
		"icon": true
	},
	"custom/quit": {
		"format": "󰗼",
		"tooltip": false,
		"on-click": "loginctl terminate-user $USER"
	},
	"custom/lock": {
		"format": "󰍁",
		"tooltip": false,
		"on-click": "hyprlock"
	},
	"custom/reboot": {
		"format": "󰜉",
		"tooltip": false,
		"on-click": "reboot"
	},
	"custom/power": {
		"format": "",
		"tooltip": false,
		"on-click": "shutdown now"
	}
}
