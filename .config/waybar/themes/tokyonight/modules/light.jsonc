{
	"backlight": {
		"device": "intel_backlight",
		"format": "{icon} {percent}%",
		"format-icons": [
			"ΌΠΧ",
			"ΌΠΨ",
			"ΌΠΩ",
			"ΌΠα",
			"ΌΠβ",
			"ΌΠγ",
			"ΌΠδ",
			"ΌΠζ",
			"ΌΠη",
			"ΌΠθ",
			"ΌΠι",
			"ΌΠκ",
			"ΌΠλ",
			"ΌΠμ"
		],
		"on-scroll-up": "brightnessctl set +5%",
		"on-scroll-down": "brightnessctl set 5%-"
	},
	"backlight/slider": {
		"device": "intel_backlight",
		"min": 0,
		"max": 100,
		"orientation": "horizontal"
	}
}
