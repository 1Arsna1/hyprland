{
	"wireplumber": {
		"format": "{icon} {volume}%",
		"ormat-muted": "´ÇĞ",
		"format-icons": ["´ÇĞ", "´Çğ", "´Ç¿"],
		"format-muted": "¯╗¿",
		"on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
